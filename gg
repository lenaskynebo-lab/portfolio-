<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Елена Брендон</title>
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;700;900&family=Manrope:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --blue: #1346d4;
    --red: #e0233c;
    --white: #ffffff;
    --cream: #f5f0e8;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--blue);
    color: var(--white);
    font-family: 'Manrope', sans-serif;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 20% 50%, rgba(45,111,255,0.3) 0%, transparent 60%),
                radial-gradient(ellipse 60% 80% at 80% 30%, rgba(10,30,100,0.5) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 0 6vw;
    position: relative;
    z-index: 2;
    gap: 4vw;
  }

  .hero-left {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .avatar-wrap {
    position: relative;
    width: clamp(260px, 38vw, 500px);
  }

  .avatar-wrap img {
    width: 100%;
    filter: drop-shadow(0 20px 60px rgba(0,0,0,0.4));
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(-1deg); }
    50% { transform: translateY(-16px) rotate(1deg); }
  }

  .tag-line {
    font-size: clamp(10px, 1.2vw, 13px);
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: 1.2rem;
  }

  .hero-name {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(34px, 5vw, 76px);
    font-weight: 900;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-size: clamp(13px, 1.3vw, 15px);
    font-weight: 300;
    opacity: 0.7;
    line-height: 1.8;
    max-width: 400px;
    margin-bottom: 2rem;
  }

  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .pill {
    padding: 0.35rem 1rem;
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 100px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    background: rgba(255,255,255,0.05);
  }

  .tg-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.9rem 1.8rem;
    background: var(--red);
    color: white;
    text-decoration: none;
    font-family: 'Unbounded', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 100px;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 8px 30px rgba(224,35,60,0.4);
  }

  .tg-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(224,35,60,0.5);
  }

  /* ACCORDION SECTION */
  .accordion-section {
    position: relative;
    z-index: 2;
    padding: 0 6vw 8rem;
  }

  .section-label {
    font-family: 'Unbounded', sans-serif;
    font-size: 11px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    opacity: 0.4;
    margin-bottom: 3rem;
  }

  .accordion {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .acc-item {
    border: 1px solid rgba(255,255,255,0.1);
    overflow: hidden;
    transition: border-color 0.3s;
  }

  .acc-item.active {
    border-color: rgba(255,255,255,0.25);
  }

  .acc-trigger {
    width: 100%;
    background: rgba(255,255,255,0.03);
    border: none;
    color: white;
    padding: 2.5rem 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    transition: background 0.3s;
    text-align: left;
    gap: 2rem;
  }

  .acc-trigger:hover { background: rgba(255,255,255,0.07); }
  .acc-item.active .acc-trigger { background: rgba(255,255,255,0.06); }

  .acc-trigger-left {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .acc-num {
    font-family: 'Unbounded', sans-serif;
    font-size: 12px;
    opacity: 0.3;
    letter-spacing: 0.15em;
    min-width: 28px;
  }

  .acc-icon { font-size: 2rem; }

  .acc-title {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(18px, 2.5vw, 32px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .acc-arrow {
    width: 48px;
    height: 48px;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    transition: transform 0.4s, background 0.3s, border-color 0.3s;
    flex-shrink: 0;
  }

  .acc-item.active .acc-arrow {
    transform: rotate(45deg);
    background: var(--red);
    border-color: var(--red);
  }

  /* Accordion body */
  .acc-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .acc-item.active .acc-body {
    max-height: 1200px;
  }

  .acc-inner {
    padding: 0 3rem 3rem;
  }

  .acc-divider {
    height: 1px;
    background: rgba(255,255,255,0.08);
    margin-bottom: 3rem;
  }

  .acc-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-bottom: 3rem;
  }

  .acc-desc {
    font-size: 15px;
    line-height: 1.9;
    opacity: 0.7;
    font-weight: 300;
  }

  .acc-list {
    list-style: none;
  }

  .acc-list li {
    padding: 0.8rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    font-size: 14px;
    opacity: 0.75;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .acc-list li::before {
    content: '→';
    opacity: 0.4;
    font-size: 12px;
    flex-shrink: 0;
  }

  /* Portfolio inside accordion */
  .acc-portfolio {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .acc-portfolio-item {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    aspect-ratio: 9/16;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    cursor: pointer;
    transition: background 0.3s;
  }

  .acc-portfolio-item:hover { background: rgba(255,255,255,0.08); }

  .acc-portfolio-item.wide {
    grid-column: 1 / -1;
    aspect-ratio: 16/7;
  }

  .placeholder-inner {
    text-align: center;
    opacity: 0.2;
  }

  .placeholder-inner .big {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(24px, 4vw, 56px);
    font-weight: 900;
    display: block;
    line-height: 1;
  }

  .placeholder-inner .small {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-top: 0.5rem;
    display: block;
    font-family: 'Unbounded', sans-serif;
  }

  .play-btn {
    width: 56px; height: 56px;
    border: 2px solid rgba(255,255,255,0.25);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.8rem;
  }

  .play-btn::after {
    content: '';
    width: 0; height: 0;
    border-style: solid;
    border-width: 9px 0 9px 16px;
    border-color: transparent transparent transparent rgba(255,255,255,0.5);
    margin-left: 4px;
  }

  /* PORTFOLIO SECTION */
  .portfolio-section {
    position: relative;
    z-index: 2;
    padding: 0 6vw 8rem;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
    margin-top: 3rem;
  }

  .portfolio-item {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    aspect-ratio: 16/9;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s;
  }

  .portfolio-item:hover { background: rgba(255,255,255,0.08); }
  .portfolio-item:first-child { grid-column: 1/-1; aspect-ratio: 16/6; }

  /* FOOTER */
  footer {
    padding: 5rem 6vw 4rem;
    position: relative;
    z-index: 2;
    border-top: 1px solid rgba(255,255,255,0.08);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer-name {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(20px, 3vw, 36px);
    font-weight: 900;
    text-transform: uppercase;
  }

  .footer-tg {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: white;
    text-decoration: none;
    font-size: 14px;
    opacity: 0.6;
    transition: opacity 0.2s;
  }
  .footer-tg:hover { opacity: 1; }

  /* Fade in */
  .fade-up {
    opacity: 0;
    transform: translateY(24px);
    animation: fadeUp 0.7s ease forwards;
  }
  @keyframes fadeUp { to { opacity: 1; transform: none; } }
  .fade-up:nth-child(1) { animation-delay: 0.1s; }
  .fade-up:nth-child(2) { animation-delay: 0.2s; }
  .fade-up:nth-child(3) { animation-delay: 0.3s; }
  .fade-up:nth-child(4) { animation-delay: 0.4s; }
  .fade-up:nth-child(5) { animation-delay: 0.5s; }

  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; padding: 5rem 6vw 3rem; text-align: center; }
    .hero-left { order: -1; }
    .avatar-wrap { width: 65vw; }
    .pills { justify-content: center; }
    .acc-trigger { padding: 1.8rem 1.5rem; }
    .acc-trigger-left { gap: 1rem; }
    .acc-inner { padding: 0 1.5rem 2rem; }
    .acc-content { grid-template-columns: 1fr; gap: 2rem; }
    .acc-portfolio { grid-template-columns: 1fr; }
    .acc-portfolio-item.wide { aspect-ratio: 16/9; }
    .portfolio-grid { grid-template-columns: 1fr; }
    footer { flex-direction: column; text-align: center; }
  }
</style>
</head>
